{
  "name": "physics-education-platform",
  "version": "1.0.0",
  "description": "منصة الفيزياء التعليمية الذكية - Physics Education Platform",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "NODE_ENV=development node --watch server/index.js",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js"
  },
  "keywords": [
    "education",
    "physics",
    "platform",
    "saudi",
    "teacher",
    "student",
    "لغة عربية",
    "فيزياء"
  ],
  "author": "Hussein Al-Faraj | أستاذ حسين الفرج",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "tailwindcss": "^3.3.0",
    "axios": "^1.6.0",
    "express": "^4.18.0",
    "mongoose": "^8.0.0",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.0",
    "zustand": "^4.4.0",
    "react-router-dom": "^6.20.0",
    "framer-motion": "^10.16.0",
    "recharts": "^2.10.0",
    "dayjs": "^1.11.0",
    "i18next": "^23.7.0",
    "react-i18next": "^13.5.0",
    "qrcode.react": "^1.0.1",
    "html2pdf": "^0.10.1",
    "xlsx": "^0.18.5",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.7.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^4.12.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "vite-plugin-pwa": "^0.17.0"
  }
}
